# ===========================================
# Downtime Monitor - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın:
#   cp .env.example .env
# ===========================================

# --- MySQL Veritabanı (Docker container) ---
MYSQL_ROOT_PASSWORD=BURAYA_GUCLU_SIFRE_YAZIN
MYSQL_DATABASE=downtimemonitor
MYSQL_USER=downtimemonitor
MYSQL_PASSWORD=BURAYA_GUCLU_SIFRE_YAZIN

# --- Uygulama Veritabanı Bağlantısı ---
# 'db' Docker Compose servis adıdır (container içinden erişim)
DATABASE_URL=mysql+pymysql://downtimemonitor:SIFRENIZ@db:3306/downtimemonitor?charset=utf8mb4

# --- Uygulama Güvenlik ---
SECRET_KEY=BURAYA_RASTGELE_SECRET_KEY_YAZIN

# --- Uygulama URL ---
APP_URL=https://downtime.fbu.edu.tr

# --- SAML Ayarları (Azure AD) ---
SAML_DEBUG=false
FEDERATION_METADATA_URL=https://login.microsoftonline.com/TENANT_ID/federationmetadata/2007-06/federationmetadata.xml?appid=APP_ID

# --- Monitör Kontrol Aralığı (saniye) ---
MONITOR_CHECK_INTERVAL=300
